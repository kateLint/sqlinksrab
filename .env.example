# HRM Portal Credentials (optional - can be entered via web interface)
HRM_EMPLOYEE_ID=
HRM_PASSWORD=

# Telegram Bot Token (required only for Telegram bot)
TELEGRAM_BOT_TOKEN=

# Server Port (optional, defaults to 5001)
PORT=5001

# Email Notification Settings (optional - for sending completion reports)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM_EMAIL=your-email@gmail.com
SMTP_FROM_NAME=HRM Automation System
EMAIL_ENABLED=true
