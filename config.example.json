{
  "portal": {
    "base_url": "https://hrm-portal.malam-payroll.com/1780?returnUrl=/"
  },
  "automation": {
    "target_month": "2026-01",
    "dry_run": false,
    "headless": false,
    "timeout_seconds": 30,
    "retry_attempts": 3,
    "otp_timeout_seconds": 120,
    "inter_entry_delay": 1.5
  },
  "entry_rules": {
    "skip_weekends": true,
    "skip_missing_entry_exit_flags": true,
    "handle_total_hours_only": "skip_and_flag",
    "decimal_hours_format": "standard"
  },
  "output": {
    "report_format": "csv",
    "screenshots_on_failure": true,
    "report_directory": "./output"
  }
}
